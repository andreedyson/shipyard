{
  "compilerOptions": {
    "module": "Node16",
    "strict": true,
    "moduleResolution": "node16",
    "target": "ES2023",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
